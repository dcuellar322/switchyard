---
import { formatBytes } from '@/lib/releases/recommend'
import type { ReleaseAsset, ReleaseChannel } from '@/lib/releases/types'

interface Props {
  release?: ReleaseChannel
  asset?: ReleaseAsset
  label: string
}

const { release, asset, label } = Astro.props
---

<article class:list={['release-card', 'panel', !asset && 'unavailable']}>
  <div class="card-heading">
    <div>
      <p class="eyebrow">Recommended</p>
      <h2>{label}</h2>
    </div>
    {release && <span class="version">{release.tag}</span>}
  </div>
  {asset && release ? (
    <>
      <dl>
        <div><dt>Package</dt><dd>{asset.packageType}</dd></div>
        <div><dt>Architecture</dt><dd>{asset.architecture}</dd></div>
        <div><dt>Size</dt><dd>{formatBytes(asset.sizeBytes)}</dd></div>
        <div><dt>Published</dt><dd>{new Date(release.publishedAt).toLocaleDateString('en-US', { dateStyle: 'medium', timeZone: 'UTC' })}</dd></div>
      </dl>
      <a class="button primary download" href={asset.downloadUrl}>Download {asset.name}</a>
      <div class="verification">
        <span>{asset.checksum ? '✓ SHA-256 published' : 'Checksum unavailable'}</span>
        {asset.sbomUrl && <a href={asset.sbomUrl}>SBOM</a>}
        {asset.signatureUrl && <a href={asset.signatureUrl}>Signature</a>}
        {asset.attestationUrl && <a href={asset.attestationUrl}>Attestation</a>}
      </div>
    </>
  ) : (
    <div class="unavailable-copy">
      <strong>No published stable package yet.</strong>
      <p>The signed release pipeline is implemented, but GitHub Releases does not currently expose a verified asset for this selection. Switchyard will not guess a filename or send you to an unverified mirror.</p>
      <div><a class="button" href="https://github.com/dcuellar322/switchyard/releases">Watch GitHub Releases</a><a class="button quiet" href="/docs/desktop-installation/#build-from-source">Build from source</a></div>
    </div>
  )}
</article>

<style>
  .release-card {
    padding: clamp(1.4rem, 4vw, 2.3rem);
  }

  .release-card.unavailable {
    border-style: dashed;
  }

  .card-heading {
    display: flex;
    align-items: start;
    justify-content: space-between;
    gap: 1rem;
  }

  h2 { margin: 0.3rem 0 0; font-size: 1.6rem; }

  .version {
    border: 1px solid var(--sy-border-subtle);
    border-radius: 999px;
    background: var(--sy-bg-elevated);
    color: var(--sy-text-muted);
    padding: 0.3rem 0.55rem;
    font-family: var(--sy-font-mono);
    font-size: 0.7rem;
  }

  dl {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0.65rem;
    margin-block: 1.4rem;
  }

  dl div {
    border-radius: 0.6rem;
    background: var(--sy-bg-elevated);
    padding: 0.7rem;
  }

  dt { color: var(--sy-text-soft); font-size: 0.67rem; text-transform: uppercase; }
  dd { margin: 0.2rem 0 0; font-family: var(--sy-font-mono); font-size: 0.78rem; }
  .download { width: 100%; }

  .verification {
    display: flex;
    flex-wrap: wrap;
    gap: 0.7rem;
    margin-top: 0.9rem;
    color: var(--sy-text-muted);
    font-size: 0.75rem;
  }

  .verification a { color: var(--sy-accent-primary); }
  .unavailable-copy { margin-top: 1.5rem; }
  .unavailable-copy > strong { color: var(--sy-status-warning); }
  .unavailable-copy p { color: var(--sy-text-muted); }
  .unavailable-copy div { display: flex; flex-wrap: wrap; gap: 0.65rem; margin-top: 1.2rem; }

  @media (max-width: 600px) {
    dl { grid-template-columns: 1fr 1fr; }
  }
</style>
