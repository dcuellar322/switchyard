---
import { features } from '@/content/marketing/features'

const homepageFeatures = features.slice(0, 6)
---

<section class="features container" aria-labelledby="features-title">
  <div class="section-heading">
    <div><p class="eyebrow">One operating model</p><h2 id="features-title">Everything around the project.</h2></div>
    <p>Switchyard complements Docker, Git, terminals, editors, and coding agents. It gives them a shared local project model.</p>
  </div>
  <div class="feature-grid">
    {homepageFeatures.map((feature) => (
      <a class="feature-card panel" href={`/features/${feature.slug}/`}>
        <span class="feature-icon" aria-hidden="true">{feature.icon}</span>
        <h3>{feature.title}</h3>
        <p>{feature.summary}</p>
        <span class="feature-link">Explore capability <b aria-hidden="true">→</b></span>
      </a>
    ))}
  </div>
  <a class="button quiet all-features" href="/features/">See every feature</a>
</section>

<style>
  .features {
    padding-block: clamp(5rem, 10vw, 9rem);
  }

  .section-heading {
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    align-items: end;
    gap: 2rem;
    margin-bottom: 2.4rem;
  }

  h2 {
    max-width: 12ch;
    margin: 0.45rem 0 0;
    font-size: clamp(2.6rem, 5vw, 4.8rem);
    letter-spacing: -0.05em;
    line-height: 1;
  }

  .section-heading > p {
    max-width: 34rem;
    margin: 0;
    color: var(--sy-text-muted);
    font-size: 1.02rem;
  }

  .feature-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }

  .feature-card {
    min-height: 17rem;
    padding: 1.4rem;
    text-decoration: none;
    transition: border-color 160ms ease, transform 160ms ease, background 160ms ease;
  }

  .feature-card:hover {
    border-color: var(--sy-accent-primary);
    background: var(--sy-bg-elevated);
    transform: translateY(-3px);
  }

  .feature-icon {
    display: grid;
    width: 2.5rem;
    height: 2.5rem;
    place-items: center;
    border: 1px solid color-mix(in srgb, var(--sy-accent-primary) 55%, var(--sy-border-subtle));
    border-radius: 0.72rem;
    background: color-mix(in srgb, var(--sy-accent-primary) 10%, var(--sy-bg-elevated));
    color: var(--sy-accent-primary);
    font-family: var(--sy-font-mono);
    font-weight: 800;
  }

  h3 {
    margin: 1.35rem 0 0.6rem;
    font-size: 1.12rem;
  }

  .feature-card p {
    color: var(--sy-text-muted);
    font-size: 0.92rem;
  }

  .feature-link {
    display: flex;
    justify-content: space-between;
    margin-top: 1.4rem;
    color: var(--sy-accent-primary);
    font-size: 0.82rem;
    font-weight: 750;
  }

  .all-features {
    margin-top: 1rem;
  }

  @media (max-width: 900px) {
    .feature-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (max-width: 650px) {
    .section-heading,
    .feature-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
