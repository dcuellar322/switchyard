---
const integrations = ['Docker Compose', 'Git', 'VS Code', 'Codex', 'Claude Code', 'MCP', 'uv', 'npm · pnpm', 'Make', 'Terminal']
---

<section class="integration-section" aria-labelledby="integration-title">
  <div class="container">
    <p class="eyebrow">Works with the tools already on your machine</p>
    <h2 id="integration-title">Connect, don’t replace.</h2>
    <div class="integration-strip">
      {integrations.map((integration) => <span>{integration}</span>)}
    </div>
    <a href="/integrations/">Explore integrations <span aria-hidden="true">→</span></a>
  </div>
</section>

<style>
  .integration-section {
    padding-block: clamp(5rem, 10vw, 8rem);
    text-align: center;
  }

  h2 {
    margin: 0.5rem 0 2.5rem;
    font-size: clamp(2.6rem, 5vw, 4.6rem);
    letter-spacing: -0.05em;
    line-height: 1;
  }

  .integration-strip {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.65rem;
  }

  .integration-strip span {
    border: 1px solid var(--sy-border-subtle);
    border-radius: 999px;
    background: var(--sy-bg-surface);
    color: var(--sy-text-muted);
    padding: 0.72rem 1rem;
    font-family: var(--sy-font-mono);
    font-size: 0.78rem;
  }

  a {
    display: inline-flex;
    gap: 0.45rem;
    margin-top: 2rem;
    color: var(--sy-accent-primary);
    font-size: 0.9rem;
    font-weight: 750;
    text-decoration: none;
  }
</style>
