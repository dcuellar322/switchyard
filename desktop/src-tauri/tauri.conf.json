{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Switchyard",
  "version": "0.1.0-alpha.0",
  "identifier": "dev.switchyard.desktop",
  "build": {
    "beforeBuildCommand": "pnpm desktop:prepare",
    "beforeDevCommand": "pnpm desktop:prepare",
    "frontendDist": "../ui"
  },
  "app": {
    "security": {
      "csp": "default-src 'self'; style-src 'self'; script-src 'self'"
    },
    "windows": [
      {
        "label": "main",
        "title": "Switchyard",
        "width": 1440,
        "height": 960,
        "minWidth": 980,
        "minHeight": 680,
        "center": true,
        "visible": false
      }
    ]
  },
  "bundle": {
    "active": true,
    "category": "DeveloperTool",
    "copyright": "Copyright Switchyard contributors",
    "createUpdaterArtifacts": false,
    "externalBin": ["binaries/switchyard"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "13.0"
    },
    "targets": ["app", "dmg"]
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["switchyard"]
      }
    }
  }
}
